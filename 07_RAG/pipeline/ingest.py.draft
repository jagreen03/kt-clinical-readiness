# ---------------------------------------------------------------------------
# Top-level walk
# ---------------------------------------------------------------------------
def iter_markdown_files(vault_root: Path) -> Iterable[Path]:
    for sub in WATCH_DIRS:
        for p in (vault_root / sub).rglob("*.md"):
            yield p


def sha256_file(path: Path) -> str:
    h = hashlib.sha256()
    h.update(path.read_bytes())
    return h.hexdigest()


